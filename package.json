{
  "name": "assay-harness",
  "version": "0.5.0",
  "description": "Open Agentsia Labs benchmark harness for model runners, reproducible rubric scoring, proof bundles, and RunRecord output.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "assay": "./dist/cli.js"
  },
  "packageManager": "pnpm@11.1.3",
  "files": [
    "dist",
    "docs/assets",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "llm-evaluation",
    "benchmark",
    "eval-harness",
    "adtech",
    "frontier-ai",
    "modelsmith",
    "runrecord",
    "reproducibility"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src tests scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "assay": "tsx src/cli.ts",
    "audit:deadcode": "knip",
    "contracts:cross-repo": "tsx scripts/validate-cross-repo-contract.ts",
    "fleet:freshness": "tsx scripts/fleet-freshness.ts",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/genai": "^1.50.1",
    "@huggingface/inference": "^4.13.15",
    "commander": "^12.1.0",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.2",
    "eslint": "^9.39.4",
    "knip": "^6.14.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.1",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentsia-uk/assay-harness.git"
  },
  "bugs": {
    "url": "https://github.com/agentsia-uk/assay-harness/issues"
  },
  "homepage": "https://agentsia.uk/labs/benchmarks/assay-adtech-v1"
}
